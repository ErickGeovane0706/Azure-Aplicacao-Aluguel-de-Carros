              "resources": {
                "requests": {
                  "memoryInGB": 1.5,
                  "cpu": 1
                }
              }
            }
          }
        ],
        "initContainers": [],
        "imageRegistryCredentials": [
          {
            "server": "acraplicacaoalugueldecarros.azurecr.io",
            "username": "acrAplicacaoAlugueldeCarros"
